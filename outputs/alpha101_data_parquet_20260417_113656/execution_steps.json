[
  {
    "output": "returns",
    "expression": "close / delay(close, 1) - 1",
    "note": "prepared directly by Polars, grouped by ths_code and ordered by time"
  },
  {
    "output": "a1_std_returns_20",
    "expression": "stddev(returns, 20)",
    "note": "Alpha#1 stage"
  },
  {
    "output": "a1_choice",
    "expression": "where(returns < 0, a1_std_returns_20, close)",
    "note": "Alpha#1 stage"
  },
  {
    "output": "a1_signed_power",
    "expression": "signedpower(a1_choice, 2)",
    "note": "Alpha#1 stage"
  },
  {
    "output": "a1_argmax_5",
    "expression": "argmax(a1_signed_power, 5)",
    "note": "Alpha#1 stage"
  },
  {
    "output": "alpha_1",
    "expression": "rank(a1_argmax_5) - 0.5",
    "note": "Alpha#1 final"
  },
  {
    "output": "a2_log_volume",
    "expression": "log(volume)",
    "note": "Alpha#2 stage"
  },
  {
    "output": "a2_delta_log_volume_2",
