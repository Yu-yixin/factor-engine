    "note": "Alpha#3 stage"
  },
  {
    "output": "alpha_3",
    "expression": "-1 * correlation(a3_open_rank, a3_volume_rank, 10)",
    "note": "Alpha#3 final"
  },
  {
    "output": "a4_low_rank",
