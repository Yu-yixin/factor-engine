    "note": "Alpha#2 stage"
  },
  {
    "output": "a2_left_rank",
    "expression": "rank(a2_delta_log_volume_2)",
    "note": "Alpha#2 stage"
  },
  {
    "output": "a2_intraday_return",
    "expression": "(close - open) / open",
    "note": "Alpha#2 stage"
  },
  {
    "output": "a2_right_rank",
    "expression": "rank(a2_intraday_return)",
    "note": "Alpha#2 stage"
  },
  {
    "output": "alpha_2",
